# Velox environment template
# Copy to .env and fill values for your deployment.

# ─── OSS 引导 ───────────────────────────────────────────────
# OSS 上的 JSON 文件,格式: {"url":["https://api1.example.com","https://api2.example.com"]}
# 客户端启动时拉这个,拿到 API 域名列表 (轮询容灾)
# 然后对每个 API 域名拼接 /velox/config.json 拉业务配置
# 换 API 域名只改 OSS 上的 JSON,无需重打包 App
OSS_URL=https://oss1.example.com/host.json

API_VERSION=v1

# Optional dev account (for local testing only)
DEV_EMAIL=
DEV_PASSWORD=

# Ops reference (not used directly by app runtime)
SERVER_HOST=
SERVER_TOKEN=
BASH_BASE_URL=https://your-edge-function-domain.com

# ─── 反馈通道:Telegram log-bot(用户"上传 debug 日志"走这里)──────────
# 独立 log-bot,只发到一个私密的客服频道。@BotFather 建 bot 拿 token;
# bot 加进频道设为管理员;频道发一条消息后调 getUpdates 拿到 chat_id
# (私密频道以 -100 开头)。留空 → app 端"上传"按钮 disabled + 提示未配置。
TG_LOG_BOT_TOKEN=
TG_LOG_CHAT_ID=
